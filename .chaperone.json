{
  "version": "1.0.0",
  "extends": [
    "chaperone/pure-functions",
    "chaperone/presentational-components"
  ],
  "project": {
    "typescript": {
      "detected": true,
      "configPath": "tsconfig.json",
      "settings": {
        "strict": true,
        "target": "ES2020"
      }
    },
    "eslint": {
      "detected": true,
      "configPath": "eslint.config.js",
      "configFormat": "flat"
    },
    "prettier": {
      "detected": false
    },
    "packageManager": {
      "name": "npm",
      "lockfile": "package-lock.json"
    }
  },
  "rules": {
    "custom": [
      {
        "type": "regex",
        "id": "no-use-super-glob-in-rust-backend",
        "severity": "error",
        "files": "src-tauri/src/**/*.rs",
        "exclude": [
          "src-tauri/src/**/tests.rs",
          "src-tauri/src/**/*test*.rs"
        ],
        "pattern": "use\\s+super::\\*;",
        "message": "Prefer explicit Rust imports over use super::* in non-test backend modules."
      },
      {
        "type": "regex",
        "id": "tauri-commands-only-in-command-boundaries",
        "severity": "error",
        "files": "src-tauri/src/**/*.rs",
        "exclude": [
          "src-tauri/src/commands.rs",
          "src-tauri/src/**/commands.rs"
        ],
        "pattern": "#\\[tauri::command\\]",
        "message": "Keep #[tauri::command] functions in commands.rs or feature-local commands.rs boundary files."
      },
      {
        "type": "regex",
        "id": "no-provider-runner-definitions-in-agent-runtime-mod",
        "severity": "error",
        "files": "src-tauri/src/agent_runtime/mod.rs",
        "pattern": "(?:async\\s+)?fn\\s+run_(claude|codex|cursor|gemini|opencode)_turn_process\\b",
        "message": "Keep provider turn-process implementations in dedicated agent_runtime provider modules, not mod.rs."
      },
      {
        "type": "regex",
        "id": "agent-runtime-mod-no-extracted-helper-definitions",
        "severity": "error",
        "files": "src-tauri/src/agent_runtime/mod.rs",
        "pattern": "(?:pub(?:\\([^)]*\\))?\\s+)?(?:async\\s+)?fn\\s+(?:summarize_session|build_capabilities|default_persistence_path|load_persisted_sessions|normalize_persisted_session|default_attachment_base_dir|session_attachment_dir|resolve_staged_attachment_path|attachment_kind_from_mime_type|build_attachment_filename|read_provider_thread_id|read_provider_text_delta|read_provider_activity_id|read_provider_activity_title|split_provider_output_chunks|ensure_assistant_message|append_assistant_text|append_assistant_paragraph|assistant_message_text|complete_activity|create_activity|refresh_activity_metadata|derive_activity_metadata|truncate_details|truncate_json_details|push_runtime_event|apply_session_failure|now_ms)\\b",
        "message": "Keep extracted agent_runtime helpers out of mod.rs; define them in focused backend modules instead."
      },
      {
        "type": "regex",
        "id": "no-serde-dtos-in-agent-runtime-provider-files",
        "severity": "error",
        "files": "src-tauri/src/agent_runtime/{claude,codex,cursor,gemini,opencode}.rs",
        "pattern": "#\\[derive\\([^\\]]*(?:Serialize|Deserialize)[^\\]]*\\)\\]",
        "message": "Keep serde DTOs out of provider runtime files; move shared API types to agent_runtime/types.rs."
      },
      {
        "type": "regex",
        "id": "provider-registry-no-runtime-mutation-imports",
        "severity": "error",
        "files": "src-tauri/src/agent_runtime/provider_registry.rs",
        "pattern": "use\\s+.*\\b(?:AgentRuntimeState|append_assistant_text|append_assistant_paragraph|ensure_assistant_message|complete_activity|create_activity|push_runtime_event|apply_session_failure|session_attachment_dir|resolve_staged_attachment_path|load_persisted_sessions|mutate_session)\\b",
        "message": "Keep provider_registry focused on readiness/model discovery, not runtime mutation or persistence helpers."
      },
      {
        "type": "regex",
        "id": "no-side-effects-in-presentational",
        "severity": "error",
        "files": "src/**/*.presentational.tsx",
        "pattern": "\\b(invoke|Database\\.load|spawn)\\b",
        "message": "Presentational components must not use Tauri-specific side effects (invoke, Database.load, spawn)"
      },
      {
        "type": "regex",
        "id": "no-tauri-imports-in-presentational",
        "severity": "error",
        "files": "src/**/*.presentational.tsx",
        "pattern": "@tauri-apps/",
        "message": "Presentational components must not import Tauri APIs"
      },
      {
        "type": "regex",
        "id": "warn-no-raw-modal-overlay-shell",
        "severity": "error",
        "files": "src/{app,widgets,features,entities}/**/*.tsx",
        "pattern": "fixed\\s+inset-0[^\\\"\\n]*bg-black/50",
        "message": "Use shared ModalShell/ModalOverlay primitives instead of ad-hoc overlay shells."
      },
      {
        "type": "regex",
        "id": "warn-no-raw-button-outside-shared-ui",
        "severity": "error",
        "files": "src/{app,widgets,features,entities}/**/*.tsx",
        "pattern": "<button\\b",
        "message": "Prefer shared Button/IconButton primitives over raw <button> in layer UI."
      },
      {
        "type": "regex",
        "id": "warn-no-deep-shared-ui-imports",
        "severity": "error",
        "files": "src/{app,widgets,features,entities}/**/*.{ts,tsx}",
        "pattern": "from\\s+[\\\"'][^\\\"']*shared/ui/",
        "message": "Use shared public APIs (src/shared/index.ts) instead of deep shared/ui imports."
      },
      {
        "type": "regex",
        "id": "warn-duplicate-form-control-class-signature",
        "severity": "error",
        "files": "src/{app,widgets,features,entities}/**/*.tsx",
        "pattern": "className=\\\"w-full\\s+px-3\\s+py-2[^\\\"]*border\\s+border-surface",
        "message": "Prefer shared TextInput/Textarea/Select primitives for standard form controls."
      },
      {
        "type": "regex",
        "id": "no-direct-tauri-imports-in-layer-implementation-files",
        "severity": "error",
        "files": "src/{app,widgets,features,entities,shared}/{lib,model,ui,hooks,config,service}/**/*.{ts,tsx}",
        "pattern": "(?:@tauri-apps/|tauri-pty)",
        "message": "Direct Tauri imports are forbidden in non-API implementation files. Move transport calls behind *.api.ts wrappers."
      },
      {
        "type": "regex",
        "id": "no-direct-tauri-imports-in-app-root",
        "severity": "error",
        "files": "src/app/*.{ts,tsx}",
        "pattern": "(?:@tauri-apps/|tauri-pty)",
        "message": "Direct Tauri imports are forbidden outside *.api.ts files."
      },
      {
        "type": "regex",
        "id": "no-deep-entities-imports-from-app-widgets-features",
        "severity": "error",
        "files": "src/{app,widgets,features}/**/*.{ts,tsx}",
        "pattern": "from\\s+[\"'](?:(?:\\.{1,2}/)+|(?:@/|~/|src/))entities/[^/\"']+/(?:api|model|lib|ui|config|hooks)/",
        "message": "Cross-slice imports must use entity slice public APIs (src/entities/<slice>/index.ts), not deep private paths."
      },
      {
        "type": "regex",
        "id": "no-deep-shared-imports-from-app-widgets-features",
        "severity": "error",
        "files": "src/{app,widgets,features}/**/*.{ts,tsx}",
        "pattern": "from\\s+[\"'](?:(?:\\.{1,2}/)+|(?:@/|~/|src/))shared/(?:model|lib|ui|hooks)/",
        "message": "Cross-slice imports must use shared public API (src/shared/index.ts) for shared hooks/lib/ui/model imports."
      },
      {
        "type": "regex",
        "id": "no-side-effects-in-pure-files",
        "severity": "error",
        "files": "src/**/*.pure.ts",
        "pattern": "\\b(window\\.dispatchEvent|EventSource|invoke|spawn|Database\\.load)\\b",
        "message": "Pure files must not use Tauri-specific side effects (invoke, spawn, Database.load, window.dispatchEvent, EventSource)"
      },
      {
        "type": "regex",
        "id": "no-shared-config-files",
        "severity": "error",
        "files": "src/shared/config/**/*.{ts,tsx}",
        "pattern": ".+",
        "message": "src/shared/config is retired; place pure constants/helpers under src/shared/lib/*.pure.ts."
      },
      {
        "type": "component-location",
        "id": "presentational-in-legacy-components-tree",
        "severity": "error",
        "files": "src/components/**/*.presentational.tsx",
        "componentType": "presentational",
        "requiredLocation": "src/components/**",
        "mustBeIn": true,
        "message": "During Phase 1 migration, presentational components should live under src/components"
      },
      {
        "type": "component-location",
        "id": "presentational-in-features-ui",
        "severity": "error",
        "files": "src/features/**/*.presentational.tsx",
        "componentType": "presentational",
        "requiredLocation": "src/features/**/ui/**",
        "mustBeIn": true,
        "message": "Feature presentational components should live under a ui/ folder"
      },
      {
        "type": "component-location",
        "id": "presentational-in-widgets-ui",
        "severity": "error",
        "files": "src/widgets/**/*.presentational.tsx",
        "componentType": "presentational",
        "requiredLocation": "src/widgets/**/ui/**",
        "mustBeIn": true,
        "message": "Widget presentational components should live under a ui/ folder"
      },
      {
        "type": "component-location",
        "id": "presentational-in-entities-ui",
        "severity": "error",
        "files": "src/entities/**/*.presentational.tsx",
        "componentType": "presentational",
        "requiredLocation": "src/entities/**/ui/**",
        "mustBeIn": true,
        "message": "Entity presentational components should live under a ui/ folder"
      },
      {
        "type": "component-location",
        "id": "presentational-in-shared-ui",
        "severity": "error",
        "files": "src/shared/**/*.presentational.tsx",
        "componentType": "presentational",
        "requiredLocation": "src/shared/ui/**",
        "mustBeIn": true,
        "message": "Shared presentational components should live under src/shared/ui"
      },
      {
        "type": "regex",
        "id": "no-legacy-layer-imports",
        "severity": "error",
        "files": "src/**/*.{ts,tsx}",
        "pattern": "from\\s+[\"'](?:@/|~/|src/)(?:components|hooks|lib)/",
        "message": "Legacy root imports from src/components, src/hooks, and src/lib are not allowed"
      },
      {
        "type": "regex",
        "id": "no-legacy-components-files",
        "severity": "error",
        "files": "src/components/**/*.{ts,tsx}",
        "pattern": ".+",
        "message": "src/components is retired; place code in app/shared/entities/features/widgets layers"
      },
      {
        "type": "regex",
        "id": "no-legacy-hooks-files",
        "severity": "error",
        "files": "src/hooks/**/*.ts",
        "pattern": ".+",
        "message": "src/hooks is retired; move hooks to slice-local or shared hooks"
      },
      {
        "type": "regex",
        "id": "no-legacy-lib-files",
        "severity": "error",
        "files": "src/lib/**/*.ts",
        "pattern": ".+",
        "message": "src/lib is retired; move utilities to app/shared/entities/features/widgets lib folders"
      },
      {
        "type": "regex",
        "id": "warn-no-hardcoded-agent-provider-unions-outside-runtime-types",
        "severity": "warning",
        "files": "src/{app,widgets,features,entities}/**/*.{ts,tsx}",
        "pattern": "\"claude\"\\s*\\|\\s*\"codex\"",
        "message": "Do not hardcode narrow claude|codex provider unions in app/widgets/features/entities code. Use shared AgentRuntimeProvider-based types."
      },
      {
        "type": "regex",
        "id": "warn-no-hardcoded-agent-provider-select-items",
        "severity": "warning",
        "files": "src/{app,widgets,features,entities}/**/*.tsx",
        "pattern": "(?:<SelectItem\\s+value=\\\"(?:claude|codex)\\\"|<option\\s+value=\\\"(?:claude|codex)\\\")",
        "message": "Provider selectors should render from shared provider metadata instead of hardcoded claude/codex options."
      },
      {
        "type": "regex",
        "id": "warn-no-hardcoded-agent-provider-defaults",
        "severity": "warning",
        "files": "src/{app,widgets,features,entities}/**/*.{ts,tsx}",
        "exclude": [
          "src/**/*.test.ts",
          "src/**/*.pure.test.ts"
        ],
        "pattern": "(?:DEFAULT_(?:AGENT|PROVIDER)[A-Z_]*\\s*=\\s*\\\"(?:claude|codex|cursor|gemini)\\\"|\\b(?:agent|selectedAgent)\\s*:\\s*\\\"(?:claude|codex|cursor|gemini)\\\")",
        "message": "Provider defaults should come from shared provider helpers instead of hardcoded string literals."
      },
      {
        "type": "regex",
        "id": "no-legacy-agent-runtime-capability-fields",
        "severity": "error",
        "files": "src/**/*.{ts,tsx}",
        "pattern": "\\b(?:claudeCliSupported|codexCliSupported|codexAppServerSupported|modelOptionsByProvider|defaultModelByProvider)\\b",
        "message": "Legacy hardcoded agent-runtime capability fields are retired. Use the provider descriptor registry instead."
      },
      {
        "type": "package-fields",
        "id": "pure-function-check-wired-into-unit-tests",
        "severity": "error",
        "requiredFields": [
          "scripts.test:pure",
          "scripts.test:unit"
        ],
        "fieldPatterns": {
          "scripts.test:pure": "chaperone\\s+check",
          "scripts.test:unit": "test:pure"
        },
        "message": "package.json must enforce pure-function test checks via test:pure and test:unit"
      },
      {
        "type": "symbol-reference",
        "id": "pure-function-exports-referenced-in-unit-tests",
        "severity": "error",
        "sourceFiles": "src/**/*.pure.ts",
        "targetFiles": "src/**/*.pure.test.ts",
        "symbolKinds": [
          "function-declaration",
          "function-variable"
        ],
        "message": "Exported pure functions must be referenced in unit tests"
      },
      {
        "type": "regex",
        "id": "no-pure-tests-in-legacy-unit-folder",
        "severity": "error",
        "files": "tests/unit/**/*.test.ts",
        "pattern": "\\.pure",
        "message": "Pure tests must be colocated as sibling *.pure.test.ts files under src/**"
      },
      {
        "type": "regex",
        "id": "no-direct-sql-plugin-import",
        "severity": "error",
        "files": "src/**/*.{ts,tsx}",
        "exclude": [
          "src/shared/api/database.api.ts",
          "src/shared/api/drizzle.api.ts"
        ],
        "pattern": "@tauri-apps/plugin-sql",
        "message": "Direct @tauri-apps/plugin-sql imports are forbidden. Use Drizzle ORM via src/shared/api/drizzle.api.ts"
      },
      {
        "type": "regex",
        "id": "no-raw-db-import-in-entities",
        "severity": "error",
        "files": "src/{entities,features}/**/*.{ts,tsx}",
        "pattern": "from\\s+[\"'].*database\\.api[\"']",
        "message": "Entity/feature files must not import from database.api.ts. Use Drizzle ORM via drizzle.api.ts instead."
      },
      {
        "type": "regex",
        "id": "no-raw-sql-strings",
        "severity": "error",
        "files": "src/**/*.{ts,tsx}",
        "exclude": [
          "src/shared/api/database.api.ts"
        ],
        "pattern": "\\b(INSERT\\s+INTO|DELETE\\s+FROM|UPDATE\\s+\\w+\\s+SET|SELECT\\s+.*\\s+FROM|ALTER\\s+TABLE|CREATE\\s+TABLE)\\b",
        "message": "Raw SQL strings are forbidden in TypeScript runtime code. Use Drizzle ORM query builder; schema bootstrap SQL is allowed only in src/shared/api/database.api.ts."
      }
    ]
  },
  "include": [
    "src/**/*",
    "src-tauri/src/**/*",
    "tests/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "build"
  ],
  "integrations": {
    "respectEslintIgnore": true,
    "respectPrettierIgnore": false,
    "useTypescriptPaths": true
  }
}
